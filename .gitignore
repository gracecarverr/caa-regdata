# ---- data -------------------------------------------------------------------
# Raw downloads are immutable but not tracked (large; rebuilt via 01_download).
# Keep the .gitkeep and the provenance MANIFEST.
data/raw/*
!data/raw/.gitkeep
!data/raw/MANIFEST.csv
# Built panels are rebuilt from code.
data/panels/*
!data/panels/.gitkeep
# Clean assets + their generated dictionaries are rebuilt from code (force-add lookups case by case).
data/clean/*
!data/clean/.gitkeep

# docs/index.html is GENERATED (by scripts/03_build_site.R) but tracked on purpose, so GitHub Pages
# serves it directly with no build step. Regenerate with run_all.R.

# ---- R / renv ---------------------------------------------------------------
renv/library/
renv/local/
renv/cellar/
renv/staging/
.Rhistory
.RData
.Rproj.user/
*.Rproj

# ---- Quarto -----------------------------------------------------------------
docs/_site/
docs/.quarto/
/.quarto/

# ---- OS ---------------------------------------------------------------------
.DS_Store
