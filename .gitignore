# ---- data -------------------------------------------------------------------
# Raw downloads are immutable but not tracked (large; rebuilt via 01_download).
# Keep the .gitkeep and the provenance MANIFEST.
data/raw/*
!data/raw/.gitkeep
!data/raw/MANIFEST.csv
# Built panels are rebuilt from code.
data/panels/*
!data/panels/.gitkeep
# Clean assets + their generated dictionaries are rebuilt from code (force-add lookups case by case).
data/clean/*
!data/clean/.gitkeep

# docs/dictionary.md and docs/distributions.md ARE generated (by scripts/03_document.R) but tracked
# on purpose, so they're browsable on GitHub without a build. Regenerate with run_all.R.

# ---- R / renv ---------------------------------------------------------------
renv/library/
renv/local/
renv/cellar/
renv/staging/
.Rhistory
.RData
.Rproj.user/
*.Rproj

# ---- Quarto -----------------------------------------------------------------
docs/_site/
docs/.quarto/
/.quarto/

# ---- OS ---------------------------------------------------------------------
.DS_Store
