# ---- data -------------------------------------------------------------------
# Raw downloads are immutable but not tracked (large; rebuilt via 01_download).
# Keep the .gitkeep and the provenance MANIFEST.
data/raw/*
!data/raw/.gitkeep
!data/raw/MANIFEST.csv
!data/raw/README*
# Built panels are rebuilt from code.
data/panels/*
!data/panels/.gitkeep
!data/panels/README*
# Processed (clean) assets + their generated dictionaries are rebuilt from code (force-add lookups case by case).
data/processed/*
!data/processed/.gitkeep
!data/processed/README*

# docs/index.html is GENERATED (by code/diagnostics/build_site.R) but tracked on purpose, so
# GitHub Pages serves it directly with no build step. Regenerate with code/RUN_ALL.R.

# ---- output -----------------------------------------------------------------
# sessionInfo.txt is a volatile per-run record (rewritten every run) -- don't track it.
# The generated LaTeX tables under output/tables/ are left untracked by default; force-add if you want
# to commit a snapshot alongside a paper.
output/sessionInfo.txt

# ---- R / renv ---------------------------------------------------------------
renv/library/
renv/local/
renv/cellar/
renv/staging/
.Rhistory
.RData
.Rproj.user/
*.Rproj

# ---- Quarto -----------------------------------------------------------------
docs/_site/
docs/.quarto/
/.quarto/

# ---- Local scratch ----------------------------------------------------------
# Ad-hoc preview helper: dumps the first N rows of each built panel to plain CSV for eyeballing.
code/diagnostics/preview_panels.R
data/panels/_preview/

# ---- OS ---------------------------------------------------------------------
.DS_Store
